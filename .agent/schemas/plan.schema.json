{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/plan.schema.json",
  "x-agentkit-schema-version": 1,
  "title": "Change plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["steps", "constraints"],
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "action", "reason", "verification"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "target": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "verification": {"type": "string", "minLength": 1},
          "depends_on": {"type": "array", "items": {"type": "integer"}, "default": []}
        }
      }
    },
    "constraints": {"type": "array", "items": {"type": "string"}},
    "rollback_or_recovery": {"type": "array", "items": {"type": "string"}, "default": []},
    "open_questions": {"type": "array", "items": {"type": "string"}, "default": []}
  }
}
