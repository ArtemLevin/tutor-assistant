{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/self-test.schema.json",
  "title": "AgentKit self-test result",
  "type": "object",
  "required": ["version", "ready", "checks", "warnings"],
  "properties": {
    "version": {"const": 1},
    "ready": {"type": "boolean"},
    "checks": {"type": "array", "items": {"type": "object"}},
    "warnings": {"type": "array", "items": {"type": "string"}}
  }
}
