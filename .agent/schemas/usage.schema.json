{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/usage.schema.json",
  "title": "AgentKit run usage telemetry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "run_id", "provider", "totals", "phases", "events"],
  "properties": {
    "version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "provider": {"type": "string"},
    "totals": {"$ref": "#/$defs/totals"},
    "phases": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/totals"}
    },
    "providers": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/totals"}
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "phase", "kind", "provider", "executable", "returncode", "duration_seconds", "timed_out", "usage"],
        "properties": {
          "timestamp": {"type": "string"},
          "phase": {"type": "string"},
          "kind": {"enum": ["agent", "tool"]},
          "provider": {"type": "string"},
          "executable": {"type": "string"},
          "returncode": {"type": "integer"},
          "duration_seconds": {"type": "number", "minimum": 0},
          "timed_out": {"type": "boolean"},
          "usage": {
            "type": "object",
            "required": ["input_tokens", "output_tokens", "cached_input_tokens", "reasoning_tokens", "total_tokens", "measured", "source"],
            "properties": {
              "input_tokens": {"type": "integer", "minimum": 0},
              "output_tokens": {"type": "integer", "minimum": 0},
              "cached_input_tokens": {"type": "integer", "minimum": 0},
              "reasoning_tokens": {"type": "integer", "minimum": 0},
              "total_tokens": {"type": "integer", "minimum": 0},
              "measured": {"type": "boolean"},
              "source": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "totals": {
      "type": "object",
      "required": ["agent_calls", "tool_calls", "duration_seconds", "input_tokens", "output_tokens", "cached_input_tokens", "reasoning_tokens", "total_tokens", "measured_agent_calls", "unknown_agent_calls"],
      "properties": {
        "agent_calls": {"type": "integer", "minimum": 0},
        "tool_calls": {"type": "integer", "minimum": 0},
        "duration_seconds": {"type": "number", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "reasoning_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "measured_agent_calls": {"type": "integer", "minimum": 0},
        "unknown_agent_calls": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
